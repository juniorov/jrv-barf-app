# Variables de entorno para la aplicación BARF
# Copia este archivo a .env y ajusta los valores según tu entorno

# Base de datos MongoDB
MONGO_URI=mongodb://localhost:27017/barf_dev
# Producción: mongodb+srv://user:password@cluster.mongodb.net/barf_prod

# JWT para autenticación
JWT_SECRET=tu_jwt_secret_muy_largo_y_seguro_aqui

# Prefijo para colecciones de MongoDB (opcional)
PREFIX=barf

# CORS: Origen adicional personalizado (opcional)
# La API ya permite localhost y https://foodbarf.netlify.app por defecto
# CORS_ORIGIN=https://tudominio-personalizado.com

# Puerto del servidor (opcional, por defecto 4000)
# PORT=4000

# Entorno (development/production)
NODE_ENV=development